# =============================================================================
# TELEGRAM BOT TOKENS
# =============================================================================
BOT_TOKEN_TAAKE=your_bot_token_for_taake_here
BOT_TOKEN_NINA=your_bot_token_for_nina_here

# Telegram User IDs (deine Telegram-ID und Ninas ID)
TELEGRAM_USER_ID_TAAKE=your_telegram_user_id
TELEGRAM_USER_ID_NINA=ninas_telegram_user_id

# =============================================================================
# AI (OpenRouter)
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Bevorzugtes Modell (kostenlos auf OpenRouter)
# Optionen: meta-llama/llama-3.1-8b-instruct:free, mistralai/mistral-7b-instruct:free
# Oder kostenpflichtig: anthropic/claude-3.5-sonnet, openai/gpt-4o
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
AI_MODEL_FALLBACK=nvidia_fallback

# =============================================================================
# =========================================================================
# NVIDIA NIM (Fallback - kostenlos mit Limits)
# =========================================================================
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Modell: moonshotai/kimi-k2.5 (via NVIDIA NIM - openai-completions API)
NVIDIA_MODEL=moonshotai/kimi-k2.5
# VOICE / WHISPER (Groq – kostenlos, 7.200 Sek./Tag)
# Registrierung: https://console.groq.com
# =============================================================================
GROQ_API_KEY=your_groq_api_key_here
# GROQ_BASE_URL=https://api.groq.com/openai/v1   # Standard, muss nicht geändert werden
# WHISPER_MODEL=whisper-large-v3                  # Standard

# =============================================================================
# MEMORY (mem0)
# =============================================================================
# Lokaler Modus: sqlite (kein extra Server nötig)
# Cloud-Modus: mem0 (benötigt MEM0_API_KEY)
MEMORY_MODE=local
# MEM0_API_KEY=your_mem0_api_key_if_using_cloud

# =============================================================================
# GOOGLE CALENDAR
# =============================================================================
# Pfad zur Google OAuth2 credentials.json (aus Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
# Nach erstem Login wird das Token hier gespeichert (automatisch)
GOOGLE_TOKEN_PATH_TAAKE=data/google_token_taake.json
GOOGLE_TOKEN_PATH_NINA=data/google_token_nina.json

# =============================================================================
# SCHEDULER
# =============================================================================
# Zeitzone für Erinnerungen und Morgen-Briefing
TIMEZONE=Europe/Berlin
# Uhrzeit des Morgen-Briefings (HH:MM)
MORNING_BRIEFING_TIME=08:00

# =============================================================================
# DATENBANK
# =============================================================================
DATABASE_URL=sqlite:///data/assistant.db

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/assistant.log

# =============================================================================
# SICHERHEIT
# =============================================================================
# Gemeinsame Notizen/Events nur zwischen diesen User-IDs sichtbar
SHARED_PAIR=TAAKE,NINA

# =============================================================================
# DOKUMENT-SCAN
# =============================================================================
# Google Drive Basis-Ordner-ID für Dokumente (leer = "Personal Assistant" Ordner)
DRIVE_DOCUMENTS_FOLDER_ID=
# Tesseract OCR: Mindestkonfidenz (0–100). Darunter → Vision-API Fallback
OCR_CONFIDENCE_THRESHOLD=70
# Lokale Kopie der gescannten PDFs in data/scans/ behalten
SCAN_SAVE_LOCAL=true
# Systempaket: apt install -y tesseract-ocr tesseract-ocr-deu

# =============================================================================
# REST API (FastAPI)
# =============================================================================
# JWT-Secret: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=CHANGE_ME_USE_python_c_import_secrets_print_secrets_token_hex_32
# App-Passwörter (für Login in der Flutter-App)
API_PASSWORD_TAAKE=
API_PASSWORD_NINA=
# Port und CORS
API_PORT=8000
# Erlaubte Origins für CORS (Komma-getrennt, * = alle)
API_CORS_ORIGINS=*
# Token-Laufzeit in Tagen
API_TOKEN_EXPIRE_DAYS=30
# Rate Limits (Format: "N/minute", "N/hour", "N/second")
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_DEFAULT=60/minute

# =============================================================================
# WEBHOOK DEPLOYER (Auto-Deploy bei GitHub Push)
# =============================================================================
# Secret: openssl rand -hex 32
# Gleiches Secret in GitHub → Repo → Settings → Webhooks → Secret eintragen
WEBHOOK_SECRET=change-me-generate-with-openssl-rand-hex-32
# Port des Webhook-Listeners (Firewall: TCP 9000 freigeben)
WEBHOOK_PORT=9000
# Branch der deployed wird (muss mit dem GitHub Webhook-Branch übereinstimmen)
DEPLOY_BRANCH=claude/dual-personal-assistants-0Uqna
