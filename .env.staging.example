# =============================================================================
# Staging-Umgebungsvariablen
# Kopieren nach .env.staging und Werte eintragen.
# KEINE echten Secrets hier! Nur Platzhalter und Staging-spezifische Defaults.
# =============================================================================

# --- Telegram (Staging-Bots mit eigenen Tokens) ---
BOT_TOKEN_TAAKE=staging-bot-token-taake
BOT_TOKEN_NINA=staging-bot-token-nina
TELEGRAM_USER_ID_TAAKE=0
TELEGRAM_USER_ID_NINA=0

# --- AI ---
OPENROUTER_API_KEY=staging-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL_INTENT=meta-llama/llama-3.1-8b-instruct
AI_MODEL_CHAT=google/gemma-3-27b-it

# --- Database ---
DATABASE_URL=sqlite:///data/staging.db

# --- API ---
API_SECRET_KEY=staging-secret-key-minimum-32-characters-long-here
API_PASSWORD_TAAKE=staging-password
API_PASSWORD_NINA=staging-password
API_PORT=8000
API_CORS_ORIGINS=*
API_TOKEN_EXPIRE_DAYS=7

# --- Allgemein ---
ENV=staging
MEMORY_MODE=local
TIMEZONE=Europe/Berlin
LOG_LEVEL=DEBUG

# --- Optional (leer lassen wenn nicht benoetigt) ---
GROQ_API_KEY=
OPENROUTE_API_KEY=
HOME_ADDRESS=
DRIVE_DOCUMENTS_FOLDER_ID=
OCR_CONFIDENCE_THRESHOLD=70
SCAN_SAVE_LOCAL=true
